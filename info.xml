<?xml version="1.0"?>
<extension key="nl.onvergetelijk.movereg" type="module">
  <file>movereg</file>
  <name>Move Event Registration</name>
  <description>Verplaats een deelnemer naar een ander actief event in het huidige jaar via het CiviCRM actie-menu.</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Richard van Oosterhout</author>
    <email>richard.van.oosterhout@gmail.com</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://github.com/onvergetelijk/nl.onvergetelijk.movereg</url>
    <url desc="Documentation">https://github.com/onvergetelijk/nl.onvergetelijk.movereg/wiki</url>
    <url desc="Support">https://github.com/onvergetelijk/nl.onvergetelijk.movereg/issues</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-03-27</releaseDate>
  <version>1.0.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.11</ver>
  </compatibility>
  <comments>Eerste versie van de Move Registration module voor intern gebruik.</comments>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/Movereg</namespace>
    <format>25.01.1</format>
    <angularModule>crmMovereg</angularModule>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
  </mixins>
</extension>
